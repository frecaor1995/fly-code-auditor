# Fly Code Auditor - variables de entorno
# Copia este archivo a .env.local y completa los valores cuando conectes servicios reales.

# --- IA ---
# Deja USE_MOCK_AI=true para correr sin ninguna API key (motor de reglas local).
# Cambia a false + agrega OPENAI_API_KEY para usar OpenAI real (texto e imagenes).
USE_MOCK_AI=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Sesion / auth demo ---
# Cambia este valor en produccion. Se usa para firmar la cookie de sesion (HMAC).
SESSION_SECRET=fly-electric-dev-secret-change-me

# --- Supabase (persistencia real de proyectos/consultas/revisiones) ---
# Ver README.md seccion "Conectar Supabase" para el paso a paso completo.
# Sin estas dos variables, la app sigue funcionando con los archivos JSON
# locales en data/ (modo demo). Con ambas definidas, Supabase pasa a ser la
# fuente de verdad para projects/queries/reviews/knowledge_entries.
#
# IMPORTANTE: SUPABASE_SERVICE_ROLE_KEY tiene permisos completos sobre la
# base de datos. NO debe llevar el prefijo NEXT_PUBLIC_ (eso la expondria en
# el bundle del navegador) y solo debe usarse desde codigo server-side
# (lib/db/supabaseServer.ts, API routes, Server Components).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fly Code Auditor - variables de entorno
# Copia este archivo a .env.local y completa los valores cuando conectes servicios reales.

# --- IA ---
# Deja USE_MOCK_AI=true para correr sin ninguna API key (motor de reglas local).
# Cambia a false + agrega OPENAI_API_KEY para usar OpenAI real (texto e imagenes).
USE_MOCK_AI=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Sesion / auth demo ---
# Cambia este valor en produccion. Se usa para firmar la cookie de sesion (HMAC).
SESSION_SECRET=fly-electric-dev-secret-change-me

# --- Futuro: Supabase (no usado todavia en el MVP mock) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

{
  "name": "fly-code-auditor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit tests/integration tests/regression",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:regression": "vitest run tests/regression",
    "test:coverage": "vitest run tests/unit tests/integration tests/regression --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "npm run typecheck && npm run test:coverage",
    "test:live": "node scripts/runLiveTests.js",
    "quality": "node scripts/runLintIfConfigured.js && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:regression && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "next": "^14.2.35",
    "openai": "^4.55.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-istanbul": "^4.1.10",
    "autoprefixer": "^10.4.19",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
